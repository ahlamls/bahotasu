<!--
  Command List — superadmin view for managing command definitions.
  Table with name, server, group, status, and CRUD actions.
-->
<section class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
  <div>
    <p class="text-secondary mb-1 small text-uppercase">Administration</p>
    <h1 class="h4 fw-semibold mb-0">Command management</h1>
  </div>
  <div class="d-flex gap-2">
    <a class="btn btn-outline-secondary" href="/admin/servers">Servers</a>
    <a class="btn btn-primary" href="/admin/commands/new">Create command</a>
  </div>
</section>

{{#notice}}
<div class="alert alert-success" role="alert">{{notice}}</div>
{{/notice}}
{{#error}}
<div class="alert alert-danger" role="alert">{{error}}</div>
{{/error}}

<div class="table-responsive card-lite">
  <table class="table align-middle mb-0">
    <thead>
      <tr>
        <th scope="col">Name</th>
        <th scope="col">Server</th>
        <th scope="col">Group</th>
        <th scope="col">Active</th>
        <th scope="col">Command</th>
        <th scope="col" class="text-end">Actions</th>
      </tr>
    </thead>
    <tbody>
      {{#commands}}
      <tr>
        <td>
          <div class="fw-semibold">{{name}}</div>
          <div class="text-secondary small">{{description}}</div>
        </td>
        <td>{{serverLabel}}</td>
        <td>{{groupLabel}}</td>
        <td>
          {{#isActive}}
          <span class="badge bg-success">Active</span>
          {{/isActive}}
          {{^isActive}}
          <span class="badge bg-secondary">Disabled</span>
          {{/isActive}}
        </td>
        <td><code>{{command}}</code></td>
        <td class="text-end">
          <div class="d-flex flex-wrap gap-2 justify-content-end">
            <a class="btn btn-outline-secondary btn-sm" href="/admin/commands/{{id}}/edit">Edit</a>
            <form method="post" action="/admin/commands/{{id}}/delete" onsubmit="return confirm('Delete this command?');">
              <input type="hidden" name="_csrf" value="{{csrfToken}}" />
              <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
            </form>
          </div>
        </td>
      </tr>
      {{/commands}}
      {{^commands}}
      <tr>
        <td colspan="6" class="text-center text-secondary py-4">No commands registered yet.</td>
      </tr>
      {{/commands}}
    </tbody>
  </table>
</div>
