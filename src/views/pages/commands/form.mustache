<!--
  Command Form — create/edit command definition (superadmin only).
  Fields: name, description, command string, server, group, password_required, is_active.
  The command string is a fixed shell command; no user interpolation.
-->
<section class="mb-4">
  <p class="text-secondary small text-uppercase mb-1">Administration</p>
  <h1 class="h4 fw-semibold">{{title}}</h1>
</section>

{{#error}}
<div class="alert alert-danger" role="alert">{{error}}</div>
{{/error}}

<div class="card-lite p-4">
  <form method="post" action="{{formAction}}" class="d-grid gap-3">
    <input type="hidden" name="_csrf" value="{{csrfToken}}" />

    <div class="row g-3">
      <div class="col-12 col-md-6">
        <label class="form-label small text-uppercase text-secondary" for="name">Name</label>
        <input type="text" id="name" name="name" class="form-control" value="{{nameValue}}" required maxlength="200" />
      </div>
      <div class="col-12 col-md-6">
        <label class="form-label small text-uppercase text-secondary" for="serverId">Target server</label>
        <select id="serverId" name="serverId" class="form-select">
          {{#servers}}
          <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
          {{/servers}}
          {{^servers}}
          <option value="">No servers available</option>
          {{/servers}}
        </select>
      </div>
    </div>

    <div>
      <label class="form-label small text-uppercase text-secondary" for="description">Description</label>
      <textarea id="description" name="description" rows="2" class="form-control">{{descriptionValue}}</textarea>
    </div>

    <div>
      <label class="form-label small text-uppercase text-secondary" for="command">Shell command</label>
      <textarea id="command" name="command" rows="3" class="form-control font-monospace" required>{{commandValue}}</textarea>
      <div class="form-text">The exact command string to execute. No user input is ever interpolated. Supports shell syntax (pipes, redirects).</div>
    </div>

    <div class="row g-3">
      <div class="col-12 col-md-6">
        <label class="form-label small text-uppercase text-secondary" for="groupId">Group access</label>
        <select id="groupId" name="groupId" class="form-select">
          <option value="" {{#noGroupSelected}}selected{{/noGroupSelected}}>Everyone</option>
          {{#groups}}
          <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
          {{/groups}}
        </select>
        <div class="form-text">Choose a group or leave empty for all users.</div>
      </div>
      <div class="col-12 col-md-6 d-flex align-items-end gap-3">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="passwordRequired" name="passwordRequired" value="1" {{#passwordRequired}}checked{{/passwordRequired}} />
          <label class="form-check-label" for="passwordRequired">Require password re-auth</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="isActive" name="isActive" value="1" {{#isActive}}checked{{/isActive}} />
          <label class="form-check-label" for="isActive">Active</label>
        </div>
      </div>
    </div>

    <div class="d-flex justify-content-between flex-wrap gap-2">
      <a href="/admin/commands" class="btn btn-outline-secondary">Cancel</a>
      <button type="submit" class="btn btn-primary">{{submitLabel}}</button>
    </div>
  </form>
</div>
