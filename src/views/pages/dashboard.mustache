<!--
  Unified Dashboard — displays both log cards and command cards grouped by project.
  Logs section: clickable cards linking to the log viewer.
  Commands section: half-width cards (col-md-6) with Execute button that opens
  a Bootstrap confirmation modal. Execution is submitted via AJAX, result polled.
  History button is only visible to superadmins.
-->
<section class="mb-4">
  <p class="text-secondary mb-1">Welcome back,</p>
  <h1 class="h4 fw-semibold">{{userName}}</h1>
</section>

<!-- ===== LOGS SECTION ===== -->
{{#hasLogs}}
<section class="mb-4">
  <h2 class="h5 fw-semibold mb-3 text-uppercase text-secondary">&#128451; Logs</h2>
  {{#logGroups}}
  <div class="mb-4">
    <h3 class="h6 fw-semibold mb-2">{{groupName}}</h3>
    {{#groupDescription}}
    <p class="text-secondary small mb-2">{{groupDescription}}</p>
    {{/groupDescription}}
    <div class="row g-3">
      {{#logs}}
      <div class="col-12">
        <div class="card-lite p-3 log-card" data-log-url="{{logUrl}}" role="link" tabindex="0">
          <div class="row gy-2 align-items-center">
            <div class="col-12 col-md-5">
              <div class="fw-semibold">{{name}}</div>
              {{#description}}
              <div class="text-secondary small">{{description}}</div>
              {{/description}}
              <!-- Server badge added by OpenAI Codex GPT-5 / 2026-05-19 to identify local vs remote log targets. -->
              <span class="badge bg-light text-dark mt-1">{{serverName}}</span>
            </div>
            <div class="col-12 col-md-5 text-secondary small">
              <code>{{filePath}}</code>
            </div>
            <div class="col-12 col-md-2 d-none d-md-flex justify-content-end">
              <a style="float:right !important" class="btn btn-primary btn-sm" href="{{logUrl}}">View log</a>
            </div>
          </div>
        </div>
      </div>
      {{/logs}}
    </div>
  </div>
  {{/logGroups}}
</section>
{{/hasLogs}}

<!-- ===== COMMANDS SECTION ===== -->
{{#hasCommands}}
<section class="mb-4">
  <h2 class="h5 fw-semibold mb-3 text-uppercase text-secondary">&#9889; Commands</h2>
  {{#commandGroups}}
  <div class="mb-4">
    <h3 class="h6 fw-semibold mb-2">{{groupName}}</h3>
    <div class="row g-3">
      {{#commands}}
      <div class="col-12 col-md-6">
        <div class="card-lite p-3 h-100 d-flex flex-column justify-content-between">
          <div>
            <div class="fw-semibold mb-1">{{name}}</div>
            {{#description}}
            <div class="text-secondary small mb-2">{{description}}</div>
            {{/description}}
            <div class="mb-2">
              <span class="badge bg-light text-dark">{{serverName}}</span>
              {{#passwordRequired}}
              <span class="badge bg-warning text-dark">Re-auth</span>
              {{/passwordRequired}}
              {{^isActive}}
              <span class="badge bg-secondary">Disabled</span>
              {{/isActive}}
            </div>
          </div>
          <div class="d-flex gap-2 flex-wrap mt-auto">
            {{#isActive}}
            <button
              type="button"
              class="btn btn-primary btn-sm"
              data-bs-toggle="modal"
              data-bs-target="#executeModal"
              data-command-id="{{id}}"
              data-command-name="{{name}}"
              data-command-description="{{description}}"
              data-password-required="{{passwordRequired}}"
            >Execute</button>
            {{/isActive}}
            {{^isActive}}
            <button class="btn btn-secondary btn-sm" disabled>Disabled</button>
            {{/isActive}}
            {{#superAdminNav}}
            <a class="btn btn-outline-secondary btn-sm" href="/commands/{{id}}/history">History</a>
            {{/superAdminNav}}
          </div>
        </div>
      </div>
      {{/commands}}
    </div>
  </div>
  {{/commandGroups}}
</section>
{{/hasCommands}}

<!-- ===== EMPTY STATE ===== -->
{{^hasLogs}}
{{^hasCommands}}
  <section class="card-lite p-4 text-center text-secondary">
    <p class="mb-0">No logs or commands available for your account yet.</p>
  </section>
{{/hasCommands}}
{{/hasLogs}}

<!-- ===== Execute Confirmation Modal (shared with command dashboard pattern) ===== -->
<div class="modal fade" id="executeModal" tabindex="-1" aria-labelledby="executeModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="executeModalLabel">Execute Command</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="executeFormSection">
          <p class="fw-semibold mb-1" id="executeCommandName"></p>
          <p class="text-secondary small mb-3" id="executeCommandDescription"></p>
          <div class="alert alert-warning d-flex align-items-center gap-2 mb-3" role="alert">
            <span>&#9888;</span>
            <span>You are about to execute a shell command on the target server. This action is logged for audit.</span>
          </div>
          <div id="passwordSection" class="mb-3 d-none">
            <label for="reauthPassword" class="form-label small text-uppercase text-secondary">Your password (required for this command)</label>
            <input type="password" id="reauthPassword" class="form-control" autocomplete="current-password" />
          </div>
          <div id="executionStatus" class="d-none">
            <div id="statusSpinner" class="d-flex align-items-center gap-2 mb-3">
              <div class="spinner-border spinner-border-sm" role="status"></div>
              <span class="text-secondary">Executing command...</span>
            </div>
            <div id="statusResult" class="d-none"></div>
            <pre id="executionOutput" class="bg-light p-3 rounded border overflow-auto d-none" style="max-height: 400px; font-size: 0.85rem;"></pre>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" id="modalCancelBtn">Cancel</button>
        <button type="button" class="btn btn-primary" id="modalConfirmBtn">Confirm &amp; Execute</button>
        <button type="button" class="btn btn-outline-secondary d-none" id="modalCloseBtn" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const csrfToken = "{{csrfToken}}";

    const modal = document.getElementById("executeModal");
    const confirmBtn = document.getElementById("modalConfirmBtn");
    const cancelBtn = document.getElementById("modalCancelBtn");
    const closeBtn = document.getElementById("modalCloseBtn");
    const formSection = document.getElementById("executeFormSection");
    const statusSection = document.getElementById("executionStatus");
    const statusSpinner = document.getElementById("statusSpinner");
    const statusResult = document.getElementById("statusResult");
    const outputPre = document.getElementById("executionOutput");
    const passwordSection = document.getElementById("passwordSection");
    const passwordInput = document.getElementById("reauthPassword");
    const cmdNameEl = document.getElementById("executeCommandName");
    const cmdDescEl = document.getElementById("executeCommandDescription");

    let currentCommandId = null;
    let pollingInterval = null;

    // Reset modal state when shown
    modal.addEventListener("show.bs.modal", (event) => {
      const button = event.relatedTarget;
      currentCommandId = button.getAttribute("data-command-id");
      const cmdName = button.getAttribute("data-command-name") || "";
      const cmdDesc = button.getAttribute("data-command-description") || "";
      const needsPassword = button.getAttribute("data-password-required") === "true";

      cmdNameEl.textContent = cmdName;
      cmdDescEl.textContent = cmdDesc;
      passwordSection.classList.toggle("d-none", !needsPassword);
      if (passwordInput) passwordInput.value = "";

      formSection.classList.remove("d-none");
      statusSection.classList.add("d-none");
      statusSpinner.classList.remove("d-none");
      statusResult.classList.add("d-none");
      statusResult.textContent = "";
      outputPre.classList.add("d-none");
      outputPre.textContent = "";
      confirmBtn.classList.remove("d-none");
      cancelBtn.classList.remove("d-none");
      closeBtn.classList.add("d-none");

      if (pollingInterval) {
        clearInterval(pollingInterval);
        pollingInterval = null;
      }
    });

    // Submit execution via AJAX
    const submitExecution = async () => {
      if (!currentCommandId) return;

      const body = new URLSearchParams();
      body.append("_csrf", csrfToken);
      if (!passwordSection.classList.contains("d-none") && passwordInput) {
        body.append("password", passwordInput.value);
      }

      try {
        const response = await fetch(`/commands/${currentCommandId}/execute`, {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: body.toString(),
        });
        const data = await response.json();

        if (data.error) {
          statusResult.textContent = data.error;
          statusResult.classList.add("text-danger");
          statusResult.classList.remove("d-none", "text-success");
          statusSpinner.classList.add("d-none");
          confirmBtn.classList.add("d-none");
          closeBtn.classList.remove("d-none");
          return;
        }

        // Redirect to the dedicated execution viewer page
        window.location.href = `/commands/${currentCommandId}/executions/${data.execution_id}/view`;
      } catch (err) {
        statusResult.textContent = "Network error. Please try again.";
        statusResult.classList.add("text-danger");
        statusResult.classList.remove("d-none");
        statusSpinner.classList.add("d-none");
        confirmBtn.classList.add("d-none");
        closeBtn.classList.remove("d-none");
      }
    };

    confirmBtn.addEventListener("click", submitExecution);

    // Cleanup on modal dismiss
    modal.addEventListener("hidden.bs.modal", () => {
      if (pollingInterval) {
        clearInterval(pollingInterval);
        pollingInterval = null;
      }
    });
  })();
</script>

<script>
  // Mobile log-card click navigation (unchanged)
  const mobileMatcher = window.matchMedia("(max-width: 767px)");
  const enableCardNavigation = () => {
    document.querySelectorAll(".log-card").forEach((card) => {
      card.dataset.mobileHandled = "true";
      const handler = () => {
        if (!mobileMatcher.matches) return;
        const url = card.getAttribute("data-log-url");
        if (url) window.location.href = url;
      };
      card.addEventListener("click", handler);
      card.addEventListener("keypress", (event) => {
        if (!mobileMatcher.matches) return;
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          handler();
        }
      });
    });
  };
  enableCardNavigation();
</script>
