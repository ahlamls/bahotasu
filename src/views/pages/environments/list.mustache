<!--
  Environment Management List - superadmin view for registered editable .env files.
  Deleting a row removes only Bahotasu metadata; it never deletes the target file.
  Added by OpenAI Codex GPT-5 / 2026-05-20.
-->
<section class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
  <div>
    <p class="text-secondary mb-1 small text-uppercase">Administration</p>
    <h1 class="h4 fw-semibold mb-0">Environment management</h1>
  </div>
  <a class="btn btn-primary" href="/admin/environments/new">Add environment</a>
</section>

{{#notice}}
<div class="alert alert-success" role="alert">{{notice}}</div>
{{/notice}}
{{#error}}
<div class="alert alert-danger" role="alert">{{error}}</div>
{{/error}}

<div class="table-responsive card-lite">
  <table class="table align-middle mb-0">
    <thead>
      <tr>
        <th scope="col">Title</th>
        <th scope="col">Server</th>
        <th scope="col">Group</th>
        <th scope="col">Active</th>
        <th scope="col">File path</th>
        <th scope="col" class="text-end">Actions</th>
      </tr>
    </thead>
    <tbody>
      {{#environments}}
      <tr>
        <td>
          <div class="fw-semibold">{{title}}</div>
          <div class="text-secondary small">{{description}}</div>
        </td>
        <td>{{serverLabel}}</td>
        <td>{{groupLabel}}</td>
        <td>
          {{#isActive}}
          <span class="badge bg-success">Active</span>
          {{/isActive}}
          {{^isActive}}
          <span class="badge bg-secondary">Disabled</span>
          {{/isActive}}
        </td>
        <td><code>{{filePath}}</code></td>
        <td class="text-end">
          <div class="d-flex flex-wrap gap-2 justify-content-end">
            <a class="btn btn-outline-primary btn-sm" href="/environments/{{id}}/edit">Open</a>
            <a class="btn btn-outline-secondary btn-sm" href="/admin/environments/{{id}}/edit">Edit</a>
            <a class="btn btn-outline-secondary btn-sm" href="/environments/{{id}}/history">History</a>
            <form method="post" action="/admin/environments/{{id}}/delete" onsubmit="return confirm('Delete this environment registration? The actual file will not be deleted.');">
              <input type="hidden" name="_csrf" value="{{csrfToken}}" />
              <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
            </form>
          </div>
        </td>
      </tr>
      {{/environments}}
      {{^hasEnvironments}}
      <tr>
        <td colspan="6" class="text-center text-secondary py-4">No environments registered yet.</td>
      </tr>
      {{/hasEnvironments}}
    </tbody>
  </table>
</div>
